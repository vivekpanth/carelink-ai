@model IEnumerable<CareLink.Services.ServiceMatch>
@{ViewData["Title"]="AI Match Results";}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <a asp-action="AiMatch" class="inline-flex items-center gap-1 text-blue-600 hover:underline text-sm mb-6">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    Search Again
  </a>

  @if((bool)ViewBag.IsCrisis){
    <div class="bg-red-600 text-white rounded-2xl p-5 mb-6 flex gap-4 items-start" data-aos="fade-up">
      <svg class="w-6 h-6 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div>
        <p class="font-bold text-lg mb-1">Are you in crisis right now?</p>
        <p class="text-red-100 text-sm mb-3">Our AI detected signs of distress. Please reach out immediately — help is available 24/7.</p>
        <div class="flex flex-wrap gap-3">
          <a href="tel:131114" class="bg-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm hover:bg-red-50 transition">Lifeline: 13 11 14</a>
          <a href="tel:1300224636" class="bg-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm hover:bg-red-50 transition">Beyond Blue: 1300 22 4636</a>
          <a href="tel:000" class="bg-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm hover:bg-red-50 transition">Emergency: 000</a>
        </div>
      </div>
    </div>
  }

  <div class="bg-gradient-to-r from-blue-600 to-teal-500 rounded-2xl p-6 text-white mb-8" data-aos="fade-up">
    <div class="flex items-center gap-3 mb-2">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      <h1 class="text-xl font-extrabold">AI Match Results</h1>
    </div>
    <p class="text-blue-100 text-sm">Based on: <em>"@ViewBag.Needs"</em></p>
    @if(ViewBag.Suburb!=null){<p class="text-blue-200 text-xs mt-1">Location preference: @ViewBag.Suburb</p>}
  </div>

  @if(!(bool)ViewBag.HasResults){
    <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p class="font-semibold text-gray-700 text-lg mb-1">No matches found.</p>
      <p class="text-gray-400 text-sm">Try rephrasing or <a asp-action="Index" class="text-blue-600 hover:underline">browse all services</a>.</p>
    </div>
  } else {
    <div class="space-y-5">
      @{int rank=1;}
      @foreach(var m in Model){
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm card-hover p-6" data-aos="fade-up">
          <div class="flex items-start justify-between flex-wrap gap-3 mb-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-teal-500 flex items-center justify-center text-white font-bold text-sm shadow">#@rank</div>
              <div>
                <h3 class="font-bold text-gray-900 text-lg leading-tight">@m.Service.Title</h3>
                <span class="text-xs text-blue-600 font-semibold bg-blue-50 px-2 py-0.5 rounded-full">@m.Service.Category</span>
              </div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-400 mb-1.5">AI Match Score</div>
              <div class="flex items-center gap-2">
                <div class="w-32 h-2.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-blue-500 to-teal-400 rounded-full transition-all duration-1000" style="width:@m.MatchScore%"></div>
                </div>
                <span class="text-base font-extrabold text-blue-600">@m.MatchScore%</span>
              </div>
            </div>
          </div>
          @if(!string.IsNullOrWhiteSpace(m.Explanation)){
            <div class="bg-blue-50 border border-blue-100 rounded-xl px-4 py-2.5 mb-4 flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p class="text-xs text-blue-700 leading-relaxed">@m.Explanation</p>
            </div>
          }
          <p class="text-gray-500 text-sm mb-4 leading-relaxed">@m.Service.Description</p>
          <div class="grid sm:grid-cols-2 gap-2 text-xs text-gray-400 mb-4">
            <div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>@m.Service.Address, @m.Service.Suburb @m.Service.State</div>
            @if(m.Service.Phone!=null){<div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>@m.Service.Phone</div>}
            @if(m.Service.OpeningHours!=null){<div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>@m.Service.OpeningHours</div>}
            <div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>@(m.Service.IsFree?"Free service":"Fee may apply")</div>
          </div>
          <div class="flex flex-wrap gap-2 pt-3 border-t border-gray-100">
            @if(m.Service.Phone!=null){<a href="tel:@m.Service.Phone" class="bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-4 py-2 rounded-xl transition flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>Call Now</a>}
            @if(m.Service.Website!=null){<a href="@m.Service.Website" target="_blank" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-xl transition">Visit Website</a>}
            <a asp-action="Details" asp-route-id="@m.Service.Id" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold px-4 py-2 rounded-xl transition">View Details</a>
          </div>
        </div>
        rank++;
      }
    </div>
  }
</div>
