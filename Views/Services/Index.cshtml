@model IEnumerable<CareLink.Models.Service>
@{ViewData["Title"]="Community Services";}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="mb-8" data-aos="fade-up">
    <h1 class="text-3xl font-extrabold text-gray-900">Community Services</h1>
    <p class="text-gray-500 mt-1">Find health, housing, food, mental health, employment and legal support</p>
  </div>
  <form method="get" class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 mb-8 flex flex-wrap gap-3 items-end" data-aos="fade-up">
    <div class="flex-1 min-w-[180px]">
      <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Search</label>
      <input name="query" value="@ViewBag.Query" placeholder="Keywords..." class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"/>
    </div>
    <div class="min-w-[150px]">
      <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Category</label>
      <select name="category" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
        <option value="">All Categories</option>
        @foreach(var c in (string[])ViewBag.Categories){<option value="@c" selected="@(ViewBag.Category==c?"selected":null)">@c</option>}
      </select>
    </div>
    <div class="min-w-[130px]">
      <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Suburb</label>
      <input name="suburb" value="@ViewBag.Suburb" placeholder="e.g. Sydney" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"/>
    </div>
    <button type="submit" class="btn-primary text-white font-semibold px-5 py-2.5 rounded-xl text-sm">Search</button>
    <a asp-action="Index" class="text-gray-400 hover:text-gray-600 text-sm py-2.5 px-2 transition">Clear</a>
  </form>
  @if(!Model.Any()){
    <div class="text-center py-20 bg-white rounded-2xl border border-gray-100" data-aos="fade-up">
      <svg class="w-14 h-14 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <p class="text-lg font-semibold text-gray-700 mb-1">No services found.</p>
      <p class="text-sm text-gray-400">Try different keywords or <a asp-action="AiMatch" class="text-blue-600 hover:underline">use the AI Matcher</a>.</p>
    </div>
  } else {
    <div class="mb-4 text-sm text-gray-400">@Model.Count() service(s) found</div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      @foreach(var s in Model){
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm card-hover flex flex-col overflow-hidden" data-aos="fade-up">
          <div class="h-32 bg-gradient-to-br from-blue-50 to-teal-50 relative">
            <img src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=400&auto=format&fit=crop&q=60" class="w-full h-full object-cover opacity-50" alt="@s.Title"/>
            <div class="absolute inset-0 bg-gradient-to-t from-white/70 to-transparent"></div>
            <div class="absolute bottom-2 left-3 flex gap-2">
              <span class="bg-blue-600 text-white text-xs font-semibold px-2.5 py-0.5 rounded-full">@s.Category</span>
              @if(s.IsFree){<span class="bg-green-500 text-white text-xs font-semibold px-2.5 py-0.5 rounded-full">Free</span>}
            </div>
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="font-bold text-gray-900 mb-2">@s.Title</h3>
            <p class="text-gray-500 text-sm mb-3 line-clamp-2 flex-1">@s.Description</p>
            <div class="space-y-1 text-xs text-gray-400 mb-4">
              <div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>@s.Suburb, @s.State</div>
              @if(s.Phone!=null){<div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>@s.Phone</div>}
              @if(s.OpeningHours!=null){<div class="flex items-center gap-1.5"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>@s.OpeningHours</div>}
            </div>
            <div class="flex gap-2">
              <a asp-action="Details" asp-route-id="@s.Id" class="flex-1 text-center bg-gray-50 hover:bg-blue-50 hover:text-blue-700 text-gray-700 text-sm font-semibold py-2.5 rounded-xl transition">Details</a>
              @if(s.Phone!=null){<a href="tel:@s.Phone" class="flex-1 text-center bg-green-50 hover:bg-green-100 text-green-700 text-sm font-semibold py-2.5 rounded-xl transition">Call</a>}
            </div>
            @if(User.Identity?.IsAuthenticated==true){
              <div class="mt-3 flex gap-3 pt-3 border-t border-gray-100">
                <a asp-action="Edit" asp-route-id="@s.Id" class="text-xs text-blue-500 hover:underline">Edit</a>
                <form asp-action="Delete" asp-route-id="@s.Id" method="post" onsubmit="return confirm('Delete this service?')">@Html.AntiForgeryToken()<button type="submit" class="text-xs text-red-500 hover:underline">Delete</button></form>
              </div>
            }
          </div>
        </div>
      }
    </div>
  }
</div>
