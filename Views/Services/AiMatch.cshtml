@{ViewData["Title"]="AI Service Matcher";}
<div class="min-h-screen bg-gradient-to-br from-blue-50 to-teal-50 py-16 px-4">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-10" data-aos="fade-up">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-blue-600 to-teal-500 rounded-2xl mb-5 shadow-xl">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3">AI Service Matcher</h1>
      <p class="text-gray-500 text-lg leading-relaxed">Describe your situation in plain language — DeepSeek AI finds the right services for you.</p>
    </div>
    <div class="bg-white rounded-3xl shadow-2xl p-8 border border-gray-100" data-aos="fade-up" data-aos-delay="100">
      <form asp-action="AiMatch" method="post" id="aiForm">
        @Html.AntiForgeryToken()
        @if(!ViewData.ModelState.IsValid){
          <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-5 text-sm flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            Please describe what you need help with.
          </div>
        }
        <div class="mb-5">
          <label class="block font-semibold text-gray-700 mb-2 text-sm">What do you need help with? <span class="text-red-500">*</span></label>
          <textarea name="needs" rows="5" required maxlength="500" placeholder="Describe your situation in your own words — for example: I have been feeling very anxious and stressed lately and I am struggling to pay rent..."
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-300 resize-none transition" id="needsInput"></textarea>
          <div class="flex justify-between mt-1">
            <p class="text-xs text-gray-400">Your description is private and never stored.</p>
            <span id="charCount" class="text-xs text-gray-400">0 / 500</span>
          </div>
        </div>
        <div class="mb-6">
          <label class="block font-semibold text-gray-700 mb-2 text-sm">Your Suburb <span class="text-gray-400 font-normal">(optional — improves local matches)</span></label>
          <input name="suburb" placeholder="e.g. Parramatta, Sydney" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 transition"/>
        </div>
        <button type="submit" id="submitBtn" class="w-full btn-primary text-white font-bold py-4 rounded-xl text-base shadow-lg flex items-center justify-center gap-2">
          <svg id="btnIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          <span id="btnText">Find Matching Services with AI</span>
        </button>
      </form>
    </div>
    <div class="mt-6" data-aos="fade-up" data-aos-delay="200">
      <p class="text-xs text-gray-400 text-center mb-3">Try an example description:</p>
      <div class="flex flex-wrap justify-center gap-2">
        @foreach(var ex in new[]{"I feel anxious and depressed and need counselling","I have no food and cannot pay rent this week","I was evicted and need emergency housing tonight","I need free legal advice about my visa"}){
          <button onclick="document.getElementById('needsInput').value='@ex';updateCount();" type="button" class="bg-white hover:bg-blue-50 hover:text-blue-700 text-gray-500 text-xs px-3 py-1.5 rounded-full border border-gray-200 transition shadow-sm">@ex</button>
        }
      </div>
    </div>
  </div>
</div>
@section Scripts {
<script>
function updateCount(){const v=document.getElementById('needsInput').value;document.getElementById('charCount').textContent=v.length+' / 500';}
document.getElementById('needsInput').addEventListener('input',updateCount);
document.getElementById('aiForm').addEventListener('submit',function(){
  const btn=document.getElementById('submitBtn');
  document.getElementById('btnText').textContent='Analysing with AI...';
  document.getElementById('btnIcon').innerHTML='<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
  btn.disabled=true;
});
</script>
}
