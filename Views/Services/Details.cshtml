@model CareLink.Models.Service
@{ViewData["Title"] = Model.Title;}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <a asp-action="Index" class="text-blue-600 hover:underline text-sm mb-6 inline-block">← Back to Services</a>
  <div class="bg-white rounded-3xl border border-gray-100 shadow-lg overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-teal-500 p-8 text-white">
      <div class="flex items-center gap-2 mb-3">
        <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">@Model.Category</span>
        @if (Model.IsFree) { <span class="bg-green-400/30 text-white text-xs font-semibold px-3 py-1 rounded-full">FREE</span> }
      </div>
      <h1 class="text-3xl font-extrabold mb-2">@Model.Title</h1>
      <p class="text-blue-100">@Model.Suburb, @Model.State</p>
    </div>
    <div class="p-8">
      <h2 class="font-semibold text-gray-700 mb-2">About This Service</h2>
      <p class="text-gray-600 mb-8">@Model.Description</p>
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        <div class="bg-gray-50 rounded-2xl p-4">
          <div class="text-xs font-semibold text-gray-400 mb-1">ADDRESS</div>
          <div class="text-gray-800 font-medium">@Model.Address, @Model.Suburb @Model.State</div>
        </div>
        @if (Model.Phone != null) {
          <div class="bg-gray-50 rounded-2xl p-4">
            <div class="text-xs font-semibold text-gray-400 mb-1">PHONE</div>
            <a href="tel:@Model.Phone" class="text-blue-600 font-semibold text-lg hover:underline">@Model.Phone</a>
          </div>
        }
        @if (Model.OpeningHours != null) {
          <div class="bg-gray-50 rounded-2xl p-4">
            <div class="text-xs font-semibold text-gray-400 mb-1">OPENING HOURS</div>
            <div class="text-gray-800 font-medium">@Model.OpeningHours</div>
          </div>
        }
        @if (Model.Website != null) {
          <div class="bg-gray-50 rounded-2xl p-4">
            <div class="text-xs font-semibold text-gray-400 mb-1">WEBSITE</div>
            <a href="@Model.Website" target="_blank" class="text-blue-600 hover:underline font-medium break-all">@Model.Website</a>
          </div>
        }
      </div>
      <div class="flex flex-wrap gap-3">
        @if (Model.Phone != null) { <a href="tel:@Model.Phone" class="bg-green-600 hover:bg-green-700 text-white font-bold px-6 py-3 rounded-xl transition">📞 Call Now</a> }
        @if (Model.Website != null) { <a href="@Model.Website" target="_blank" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl transition">🌐 Visit Website</a> }
      </div>
    </div>
  </div>
</div>
