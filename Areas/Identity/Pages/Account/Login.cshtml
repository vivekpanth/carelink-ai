@page
@model LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen grid lg:grid-cols-2">
  <!-- Left Panel -->
  <div class="hidden lg:flex relative overflow-hidden">
    <img src="https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?w=900&auto=format&fit=crop&q=80"
         class="absolute inset-0 w-full h-full object-cover" alt="Community"/>
    <div class="absolute inset-0 bg-gradient-to-br from-blue-900/85 to-teal-800/75"></div>
    <div class="relative z-10 flex flex-col justify-center px-14">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-11 h-11 bg-white/20 backdrop-blur rounded-xl flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <span class="text-2xl font-bold text-white">CareLink AI</span>
      </div>
      <h2 class="text-4xl font-extrabold text-white mb-4 leading-tight">Welcome Back to<br/><span class="text-teal-300">CareLink AI</span></h2>
      <p class="text-blue-100 text-lg mb-10 leading-relaxed">Sign in to manage community service listings and help vulnerable Australians find the support they deserve.</p>
      <div class="space-y-4">
        @foreach(var f in new[]{"AI-powered semantic service matching","Real-time crisis detection & support","Mobile-first responsive design","DeepSeek AI via OpenRouter"})
        {
          <div class="flex items-center gap-3">
            <div class="w-6 h-6 bg-teal-400/20 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-teal-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-blue-100 text-sm">@f</span>
          </div>
        }
      </div>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="flex items-center justify-center px-8 py-12 lg:px-16 bg-white">
    <div class="w-full max-w-md">
      <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Welcome back</h1>
        <p class="text-gray-500">Sign in to your account to continue</p>
      </div>

      <form id="account" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-5 text-sm"></div>

        <div class="mb-4">
          <label asp-for="Input.Email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email address</label>
          <input asp-for="Input.Email" autocomplete="username" placeholder="you@example.com"
                 class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-300 focus:bg-white transition"/>
          <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div class="mb-5">
          <div class="flex justify-between items-center mb-1.5">
            <label asp-for="Input.Password" class="text-sm font-semibold text-gray-700">Password</label>
            @if ((Model.ExternalLogins?.Count ?? 0) == 0)
            {
              <a asp-page="./ForgotPassword" class="text-xs text-blue-600 hover:underline font-medium">Forgot password?</a>
            }
          </div>
          <input asp-for="Input.Password" type="password" autocomplete="current-password" placeholder="Enter your password"
                 class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-300 focus:bg-white transition"/>
          <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div class="flex items-center mb-6">
          <label class="flex items-center gap-2.5 cursor-pointer select-none">
            <input asp-for="Input.RememberMe" type="checkbox" class="w-4 h-4 rounded accent-blue-600 cursor-pointer"/>
            <span class="text-sm text-gray-600">Keep me signed in</span>
          </label>
        </div>

        <button type="submit" class="w-full btn-primary text-white font-bold py-3.5 rounded-xl text-base flex items-center justify-center gap-2 shadow-lg">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
          Sign In
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-gray-500">
        Don't have an account?
        <a asp-page="./Register" class="text-blue-600 font-semibold hover:underline ml-1">Create one free</a>
      </p>
      <div class="mt-8 pt-6 border-t border-gray-100 text-center">
        <a asp-controller="Home" asp-action="Index" class="text-sm text-gray-400 hover:text-gray-600 inline-flex items-center gap-1.5 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back to CareLink AI
        </a>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial"/>
}
